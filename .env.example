# Conversational Survey Engine — Environment Variables
# Copy to .env and fill in values

# Database (NeonDB PostgreSQL or local SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/cse.db
# For NeonDB: postgresql+asyncpg://user:pass@host/dbname?ssl=require

# LLM Service URL (when running with Docker Compose, this is set automatically)
LLM_SERVICE_URL=http://localhost:8001

# Google Gemini API Key
GEMINI_API_KEY=your-gemini-api-key-here

# Google API Key (alternative)
GOOGLE_API_KEY=

# LLM Models
GEMINI_MODEL=vertex_ai/gemini-2.0-flash
GEMINI_VALIDATOR_MODEL=gemini/gemini-2.0-flash

# Google Application Credentials (path to service account JSON)
GOOGLE_APPLICATION_CREDENTIALS=./gen-lang-client-0575690477-7f0434f5aa44.json
# For Docker: path to credentials file on host
GOOGLE_CREDENTIALS_FILE=./gen-lang-client-0575690477-7f0434f5aa44.json

# CORS Origins (JSON array)
CORS_ORIGINS=["http://localhost:5173"]

# Log Level
LOG_LEVEL=info
